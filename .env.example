# HuggingFace token for pyannote.audio model download only
HF_TOKEN=

# FTP credentials (if FTP enabled)
FTP_IP_ADDRESS=
FTP_USERNAME=
FTP_PASSWORD=

# Optional: FTP date filtering (use CLI arguments as primary)
# Single date mode: 
# FTP_DATE=20260413
# Date range mode:
# FTP_DATE_START=20260410
# FTP_DATE_END=20260413